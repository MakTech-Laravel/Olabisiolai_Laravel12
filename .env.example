# =============================================================================
# LOCAL DEVELOPMENT & Docker *image build* defaults only
# =============================================================================
# Do NOT upload this file unchanged to production as /var/www/.env — the Reverb
# block below uses localhost / http and will NOT match a public wss:// SPA.
#
# For production values, start from:  .env.production.example
# Generate Reverb credentials:        php artisan reverb:install
# =============================================================================

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ASSET_URL="${APP_URL}"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=

VITE_APP_NAME="${APP_NAME}"

# CORS: comma-separated browser origins allowed to call the API (must match the SPA origin).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Laravel Reverb — fill after: php artisan reverb:install
# -----------------------------------------------------------------------------
# Leave empty until you run `reverb:install` locally; then paste the three app
# credentials here for ws://127.0.0.1:8089. Coolify production must use the
# template file .env.production.example instead of copying this block verbatim.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8089
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8089

# Optional: PHP → Reverb publish URL (see config/broadcasting.php). Use 127.0.0.1:8089 + http
# on production if broadcasts never reach clients (container cannot reach its public hostname).
# REVERB_BROADCAST_HOST=127.0.0.1
# REVERB_BROADCAST_PORT=8089
# REVERB_BROADCAST_SCHEME=http

# Messaging
MAX_ATTACHMENT_SIZE_MB=50
MAX_PARTICIPANTS_PER_CONVERSATION=50
MESSAGE_RATE_LIMIT_PER_MINUTE=60
MESSAGING_ATTACHMENT_URL_TTL=60
MESSAGING_USE_HTMLPURIFIER=true

