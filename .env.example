# =============================================================================
# LOCAL DEVELOPMENT & Docker *image build* defaults only
# =============================================================================
# Do NOT upload this file unchanged to production as /var/www/.env — the Reverb
# block below uses localhost / http and will NOT match a public wss:// SPA.
#
# For production values, start from:  .env.production.example
# Generate Reverb credentials:        php artisan reverb:install
# =============================================================================

APP_NAME=Gidira
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ASSET_URL="${APP_URL}"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Registration / verification OTP lifetime (minutes)
AUTH_OTP_EXPIRE_MINUTES=15

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Reverb credentials — MUST match REVERB_APP_* in reverb_server and
# VITE_REVERB_APP_KEY in the frontend EXACTLY.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=

# Where the backend PUBLISHES events (server-to-server, HMAC-signed HTTP POST).
#
# On Coolify, separate apps do NOT resolve each other by service name by default,
# so use the PUBLIC WS host — the request loops back through Traefik on the same
# VPS (no real internet round-trip). The WS origin check does not apply here.
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https
#
# ALTERNATIVE (internal Docker DNS) — only if both containers share a network
# (Coolify: enable "Connect To Predefined Network" on both, then use the name
# that actually resolves from the backend, e.g. the reverb_server container name):
#   REVERB_HOST=<resolvable-name>   REVERB_PORT=8080   REVERB_SCHEME=http

# Cross-origin: the SPA origin allowed to call the API and /broadcasting/auth.
FRONTEND_URL=

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional absolute URL for the logo shown in markdown emails (defaults to APP_URL/images/branding/gidira-logo.svg)
# MAIL_LOGO_URL="${APP_URL}/images/branding/gidira-logo.svg"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=

VITE_APP_NAME="${APP_NAME}"

# CORS: comma-separated browser origins allowed to call the API (must match the SPA origin).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Payments (Server-side secrets — NEVER expose to frontend)
# -----------------------------------------------------------------------------
# Paystack: used only by Laravel to verify transactions and for server-side API calls.
# Get keys from your Paystack dashboard. Use TEST keys locally, LIVE keys in production.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Termii SMS (Phone OTP)
# -----------------------------------------------------------------------------
# Get API key + Base URL from https://accounts.termii.com (copy both from dashboard).
# Leave TERMII_API_KEY empty locally to log OTPs in storage/logs/laravel.log instead.
#
# Sender ID / channel (Termii Nigeria DND — API only, not dashboard):
#   from: N-Alert
#   channel: dnd
# Approved OTP SMS format (do not change wording without Termii re-approval):
#   "Your Gidira OTP is 123456. Do not share with anyone."
TERMII_API_KEY=
TERMII_SENDER_ID=N-Alert
# Copy BASE URL from Termii dashboard (Settings). Nigeria accounts usually use api.ng.termii.com
TERMII_BASE_URL=https://api.ng.termii.com
TERMII_CHANNEL=dnd
TERMII_OTP_BRAND=Gidira
TERMII_TIMEOUT=15

# Flutterwave: if you verify transactions on the server, keep secret here.
# FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxx-X

# -----------------------------------------------------------------------------
# Laravel Reverb — fill after: php artisan reverb:install
# -----------------------------------------------------------------------------
# Leave empty until you run `reverb:install` locally; then paste the three app
# credentials here for ws://127.0.0.1:8089. Coolify production must use the
# template file .env.production.example instead of copying this block verbatim.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8089
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8089

# Optional: PHP → Reverb publish URL (see config/broadcasting.php). Use 127.0.0.1:8089 + http
# on production if broadcasts never reach clients (container cannot reach its public hostname).
# REVERB_BROADCAST_HOST=127.0.0.1
# REVERB_BROADCAST_PORT=8089
# REVERB_BROADCAST_SCHEME=http

# -----------------------------------------------------------------------------
# Social login (API) — Google enabled by default; add more providers in config/social_auth.php
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an authorized redirect URI in Google Cloud Console
GOOGLE_REDIRECT_URI="${APP_URL}/api/v1/auth/social/google/callback"
SOCIAL_AUTH_GOOGLE_ENABLED=true
# Optional SPA callback after browser redirect flow
# SOCIAL_AUTH_FRONTEND_CALLBACK_URL="${FRONTEND_URL}/auth/social/callback"

# Messaging
MAX_ATTACHMENT_SIZE_MB=50
MAX_PARTICIPANTS_PER_CONVERSATION=50
MESSAGE_RATE_LIMIT_PER_MINUTE=60
MESSAGING_ATTACHMENT_URL_TTL=60
MESSAGING_USE_HTMLPURIFIER=true

