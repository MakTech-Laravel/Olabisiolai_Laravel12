# =============================================================================
# LOCAL DEVELOPMENT & Docker *image build* defaults only
# =============================================================================
# For production (Coolify), use: docs/env.coolify.example
# Generate Reverb credentials: php artisan reverb:install (share across 3 services)
# =============================================================================

APP_NAME=Gidira
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ASSET_URL="${APP_URL}"

L5_SWAGGER_CONST_HOST="${APP_URL}/api"
L5_SWAGGER_GENERATE_ALWAYS=true
L5_FORMAT_TO_USE_FOR_DOCS=json

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Registration / verification OTP lifetime (minutes)
AUTH_OTP_EXPIRE_MINUTES=15

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Reverb credentials — MUST match REVERB_APP_* in reverb_server and
# VITE_REVERB_APP_KEY in the frontend EXACTLY.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=

# Where the backend PUBLISHES events (split architecture: separate ws host).
# Local: run olabisiolai_websocket and use ws://localhost:8080
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@gidira.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_SUPPORT_ADDRESS=hello@gidira.com

# Optional absolute URL for the logo shown in markdown emails (defaults to APP_URL/images/branding/gidira-logo.svg)
# MAIL_LOGO_URL="${APP_URL}/images/branding/gidira-logo.svg"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=

VITE_APP_NAME="${APP_NAME}"

# CORS: comma-separated browser origins allowed to call the API (must match the SPA origin).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# Allow POST /api/v1/realtime/test-broadcast outside local (default false).
# REALTIME_ALLOW_TEST_BROADCAST=false
# -----------------------------------------------------------------------------
# Paystack receipt emails (sent by Paystack, not Laravel) use the business profile in your
# Paystack Dashboard → Settings → Profile. Set business name to Gidira and support email
# to hello@gidira.com for both test and live accounts.
# Get keys from your Paystack dashboard. Use TEST keys locally, LIVE keys in production.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Termii SMS (Phone OTP)
# -----------------------------------------------------------------------------
# Get API key + Base URL from https://accounts.termii.com (copy both from dashboard).
# Leave TERMII_API_KEY empty locally to log OTPs in storage/logs/laravel.log instead.
#
# Sender ID / channel (Termii Nigeria DND — API only, not dashboard):
#   from: N-Alert
#   channel: dnd
# Approved OTP SMS format (do not change wording without Termii re-approval):
#   "Your Gidira OTP is 123456. Do not share with anyone."
TERMII_API_KEY=
TERMII_SENDER_ID=N-Alert
# Copy BASE URL from Termii dashboard (Settings). Nigeria accounts usually use api.ng.termii.com
TERMII_BASE_URL=https://api.ng.termii.com
TERMII_CHANNEL=dnd
TERMII_OTP_BRAND=Gidira
TERMII_TIMEOUT=15

# Away-message alerts (email/SMS when vendor is offline on Gidira)
MESSAGING_AWAY_ALERT_DEBOUNCE_MINUTES=15

# -----------------------------------------------------------------------------
# WhatsApp away-message alerts (notify-only; disabled until credentials are set)
# -----------------------------------------------------------------------------
# Termii: register device + template at https://accounts.termii.com/#/devices
# WHATSAPP_SENDER_ID = Termii device_id, WHATSAPP_NEW_MESSAGE_TEMPLATE = template_id
# WHATSAPP_TEMPLATE_*_KEY must match placeholder keys in your approved template.
WHATSAPP_ENABLED=false
WHATSAPP_DRIVER=termii
WHATSAPP_API_KEY=
WHATSAPP_SENDER_ID=
WHATSAPP_BASE_URL=https://api.ng.termii.com
WHATSAPP_TIMEOUT=15
WHATSAPP_NEW_MESSAGE_TEMPLATE=
WHATSAPP_TEMPLATE_SENDER_KEY=1
WHATSAPP_TEMPLATE_URL_KEY=2

# -----------------------------------------------------------------------------
# Payments (Server-side secrets — NEVER expose to frontend)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an authorized redirect URI in Google Cloud Console
GOOGLE_REDIRECT_URI="${APP_URL}/api/v1/auth/social/google/callback"
SOCIAL_AUTH_GOOGLE_ENABLED=true
# Optional SPA callback after browser redirect flow
# SOCIAL_AUTH_FRONTEND_CALLBACK_URL="${FRONTEND_URL}/auth/social/callback"

# Messaging
MAX_ATTACHMENT_SIZE_MB=50
MAX_PARTICIPANTS_PER_CONVERSATION=50
MESSAGE_RATE_LIMIT_PER_MINUTE=60
MESSAGING_ATTACHMENT_URL_TTL=60
MESSAGING_USE_HTMLPURIFIER=true
