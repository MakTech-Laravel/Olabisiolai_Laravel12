# =============================================================================
# Gidira API — Coolify production environment template
# =============================================================================
# Copy these variables into the Coolify "Environment Variables" UI for the
# api.gidira.tech service. Do NOT commit real secrets to git.
#
# WebSockets run in olabisiolai_websocket (ws.gidira.tech) — this service only
# publishes events and authorizes private channels.
# =============================================================================

APP_NAME=Gidira
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.gidira.tech
ASSET_URL=https://api.gidira.tech

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

BROADCAST_CONNECTION=reverb

# Shared with olabisiolai_websocket and frontend VITE_REVERB_APP_KEY
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=

# Backend → Reverb HTTP publish (public Traefik loopback on same VPS)
REVERB_HOST=ws.gidira.tech
REVERB_PORT=443
REVERB_SCHEME=https

# SPA origin for CORS and Reverb origin checks (via reverb_allowed_origins.php)
FRONTEND_URL=https://www.gidira.tech
CORS_ALLOWED_ORIGINS=https://www.gidira.tech,https://gidira.tech

# Optional: enable private-channel test from /ws-test (disable after verification)
REALTIME_ALLOW_TEST_BROADCAST=true

# Internal Docker DNS alternative (both services on shared Coolify network):
# REVERB_HOST=<websocket-container-name>
# REVERB_PORT=8080
# REVERB_SCHEME=http

MAIL_MAILER=smtp
# MAIL_HOST= ...
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@gidira.tech
MAIL_FROM_NAME=Gidira

# Passport keys are auto-generated on first boot if not provided via env/files.
